<?php

namespace {{namespace}}\Http\Controllers\Hook;

use Illuminate\Support\Facades\Artisan;

class Activate
{
	public function __invoke(): void
	{
		try {
			Artisan::call('migrate', ['--force' => true]);
		} catch (\Exception $e) {
			logger('Error al migrar: en plugin {{namespace}} ' . $e->getMessage());
		}
	}
}
