<?php

namespace {{namespace}}\Providers;

use App\Framework\BaseAddonServiceProvider;
use {{namespace}}\Http\Controllers\Home\HomeController;

class AddonServiceProvider extends BaseAddonServiceProvider
{
	public function register(): void
	{
		parent::register();

		$this->mergeConfigFrom(__DIR__ . '/../../config/{{slug}}.php', '{{slug}}');
	}

	public function boot(): void
	{
		parent::boot();

		app(HomeController::class);
	}
}
